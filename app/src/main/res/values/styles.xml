<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF2200</item>
        <item name="colorPrimaryVariant">#CC1800</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:windowBackground">#0D0D0D</item>
        <item name="android:statusBarColor">#111111</item>
        <item name="android:navigationBarColor">#0D0D0D</item>
    </style>

    <!-- Number buttons: dark gray -->
    <style name="BtnNum">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@drawable/btn_num_bg</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Operator buttons: red -->
    <style name="BtnOp">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@drawable/btn_op_bg</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Function buttons: dark gray with red text -->
    <style name="BtnFunc">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">#FF3333</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@drawable/btn_func_bg</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Equals button: bright red -->
    <style name="BtnEquals">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@drawable/btn_equals_bg</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

</resources>
